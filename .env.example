# ===================================================================
# DOCKER-COMPOSE ENVIRONMENT (.env)
# ===================================================================
# USE CASE: Running the entire application stack in Docker containers.
# HOW TO RUN: docker compose up -d
#
# HOW TO USE: Copy this file to '.env' in the project root. Docker Compose
# will automatically load the variables.
# ===================================================================

# -------------------------------------------------------------------
# 1. POSTGRES ADMIN
# Used ONLY by Docker to initialize the PostgreSQL server on first run.
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gym_dev

# -------------------------------------------------------------------
# 2. SPRING BOOT DATASOURCE
# Used by the Spring Boot container to connect to the database.
# -------------------------------------------------------------------
SPRING_DATASOURCE_USERNAME=gym_app
SPRING_DATASOURCE_PASSWORD=talosgym123

# -------------------------------------------------------------------
# 3. SECURITY & MAIL
# -------------------------------------------------------------------
JWT_SECRET_KEY=a-very-strong-secret-key-for-local-development-that-is-long
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# -------------------------------------------------------------------
# 4. NETWORK & PORTS
# Port mappings from the host machine to the containers.
# -------------------------------------------------------------------
DATABASE_PORT=5433
BACKEND_PORT=8080
FRONTEND_PORT=3000

# -------------------------------------------------------------------
# 5. APPLICATION CONFIGURATION
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
APP_LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
NODE_ENV=development
