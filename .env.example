# ===================================================================
# DOCKER-COMPOSE ENVIRONMENT (.env)
# ===================================================================
# USE CASE: Running the entire application stack in Docker containers.
# HOW TO RUN: docker compose up -d
#
# HOW TO USE: Copy this file to '.env' in the project root. Docker Compose
# will automatically load the variables.
# ===================================================================

# -------------------------------------------------------------------
# 1. POSTGRES ADMIN
# Used ONLY by Docker to initialize the PostgreSQL server on first run.
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gym_dev

# -------------------------------------------------------------------
# 2. SPRING BOOT DATASOURCE
# Used by the Spring Boot container to connect to the database.
# -------------------------------------------------------------------
SPRING_DATASOURCE_USERNAME=gym_app
SPRING_DATASOURCE_PASSWORD=talosgym123

# -------------------------------------------------------------------
# 3. SECURITY (JWT)
# -------------------------------------------------------------------
# Base64-encoded secret key for signing JWT tokens (min 256-bit recommended for HS256)
JWT_SECRET_KEY=a-very-strong-secret-key-for-local-development-that-is-long

# -------------------------------------------------------------------
# 4. MAIL CONFIGURATION (SMTP)
# -------------------------------------------------------------------
# Sender email address for invitation and verification mails (Gmail recommended)
SPRING_MAIL_USERNAME=
# App-specific password for the mail account (e.g., Gmail App Password)
SPRING_MAIL_PASSWORD=

# -------------------------------------------------------------------
# 5. INTEGRATIONS (External APIs)
# -------------------------------------------------------------------
# External webhook URL for Macrodroid SMS integration (used for OTP delivery)
MACRODROID_WEBHOOK_URL=
# Security secret to authenticate requests sent to the Macrodroid webhook
MACRODROID_WEBHOOK_SECRET=

# API key for LocationIQ geocoding service (used for club location searching)
LOCATIONIQ_API_KEY=

# -------------------------------------------------------------------
# 6. NETWORK & PORTS
# Port mappings from the host machine to the containers.
# -------------------------------------------------------------------
# Accessible PostgreSQL port on the host machine
DATABASE_PORT=5433
# Accessible Spring Boot API port on the host machine
BACKEND_PORT=8080
# Accessible Next.js Frontend port on the host machine
FRONTEND_PORT=3000

# -------------------------------------------------------------------
# 7. APPLICATION CONFIGURATION
# -------------------------------------------------------------------
# Active Spring profile (dev, prod, test). Determines configuration overrides.
SPRING_PROFILES_ACTIVE=dev
# Logging level for the application (DEBUG, INFO, WARN, ERROR)
APP_LOG_LEVEL=INFO
# Full URL to the frontend for CORS and link generation (e.g., mail links)
FRONTEND_URL=http://localhost:3000
# Base API URL used for internal routing and redirection
BACKEND_URL=http://localhost:8080
# Node environment (development, production) for the Next.js app
NODE_ENV=development

# -------------------------------------------------------------------
# 8. REDIS CONFIGURATION
# Used by the Spring Boot container to connect to Redis.
# -------------------------------------------------------------------
# Fully qualified Redis connection URL (Internal Docker host is 'redis')
SPRING_DATA_REDIS_URL=redis://redis:6379
