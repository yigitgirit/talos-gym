# ===================================================================
# SPRING BOOT - SOURCE ENVIRONMENT VARIABLES
# ===================================================================
# This file contains environment variables for running Spring Boot locally
# Copy this to .env and update with your values

# JWT secret key (should match frontend)
JWT_SECRET_KEY=aPsS1atSLD8l25Khjw2Z7dNNXvl3KW9pQyIOyDto3ZE=SWORD=

# Database connection
# Default points to localhost:5433 (Docker container mapped port)
# If using a locally installed Postgres on default port, change to 5432
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/gym_dev
SPRING_DATASOURCE_USERNAME=gym_app
SPRING_DATASOURCE_PASSWORD=talosgym123

# Email configuration
SPRING_MAIL_USERNAME=yigitgirit07@gmail.com
SPRING_MAIL_PASSWORD='neyd begs wytd lpov'

# Active Spring Profile (dev or prod)
# Default is dev, so you usually don't need to set this locally unless testing prod
SPRING_PROFILES_ACTIVE=dev

# Frontend URL for CORS configuration
# Default is http://localhost:3000 in dev profile, so you can leave this empty locally
FRONTEND_URL=http://localhost:3000

# Log level for your application's package (INFO, DEBUG, TRACE)
APP_LOG_LEVEL=DEBUG