# ===================================================================
# LOCAL DEVELOPMENT ENVIRONMENT (.env)
# ===================================================================
# USE CASE: Running the Spring Boot application locally (via Maven, Gradle, or an IDE).
# PRE-REQUISITE: A PostgreSQL database must be running (e.g., via Docker).
# HOW TO RUN DB: docker compose -f ../../docker-compose.db.yaml up -d
#
# HOW TO USE: Copy this file to '.env' and load it before starting the app.
# ===================================================================

# -------------------------------------------------------------------
# Database Connection
# Connection string and credentials for the local application user.
# -------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/gym_dev
SPRING_DATASOURCE_USERNAME=gym_app
SPRING_DATASOURCE_PASSWORD=talosgym123

# -------------------------------------------------------------------
# Security
# Secret key used for signing JWT tokens.
# -------------------------------------------------------------------
JWT_SECRET_KEY=a-very-strong-secret-key-for-local-development-that-is-long

# -------------------------------------------------------------------
# Mail Server (SMTP)
# Credentials for the email sending service.
# -------------------------------------------------------------------
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# -------------------------------------------------------------------
# SMS Configuration (MacroDroid)
# Webhook URL and Secret Token for sending SMS locally via MacroDroid.
# -------------------------------------------------------------------
MACRODROID_WEBHOOK_URL=https://trigger.macrodroid.com/your-device-id/sms
MACRODROID_WEBHOOK_SECRET=your-secret-token

# -------------------------------------------------------------------
# Application Behavior
# Spring Boot active profile and logging configuration.
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
APP_LOG_LEVEL=INFO