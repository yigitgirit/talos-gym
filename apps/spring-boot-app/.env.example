# ===================================================================
# LOCAL DEVELOPMENT ENVIRONMENT (.env)
# ===================================================================
# USE CASE: Running the Spring Boot application locally (via Maven, Gradle, or an IDE).
# PRE-REQUISITE: A PostgreSQL database must be running (e.g., via Docker).
# HOW TO RUN DB: docker compose -f ../../docker-compose.db.yaml up -d
#
# HOW TO USE: Copy this file to '.env' and load it before starting the app.
# ===================================================================

# -------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (PostgreSQL)
# -------------------------------------------------------------------
# The JDBC connection URL for the gymnast database.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/gym_dev
# Database username for the application user.
SPRING_DATASOURCE_USERNAME=gym_app
# Database password for the application user.
SPRING_DATASOURCE_PASSWORD=talosgym123

# -------------------------------------------------------------------
# 2. CACHE CONFIGURATION (Redis)
# -------------------------------------------------------------------
# Redis connection URL for session management and caching.
SPRING_DATA_REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------------
# 3. SECURITY & AUTHENTICATION
# -------------------------------------------------------------------
# A secure, long string for HS256 signing of JWT tokens.
JWT_SECRET_KEY=a-very-strong-secret-key-for-local-development-that-is-long

# -------------------------------------------------------------------
# 4. EXTERNAL SERVICES & APIS
# -------------------------------------------------------------------
# SMTP credentials for sending emails (e.g., Mailtrap, Gmail).
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# LocationIQ API key for geocoding and map services.
LOCATIONIQ_API_KEY=

# SMS integration via MacroDroid webhooks (local testing).
MACRODROID_WEBHOOK_URL=https://trigger.macrodroid.com/your-device-id/sms
MACRODROID_WEBHOOK_SECRET=your-secret-token

# -------------------------------------------------------------------
# 5. CROSS-ORIGIN RESOURCE SHARING (CORS)
# -------------------------------------------------------------------
# The URL of the frontend application.
FRONTEND_URL=http://localhost:3000

# -------------------------------------------------------------------
# 6. APPLICATION RUNTIME SETTINGS
# -------------------------------------------------------------------
# Spring active profile (dev, prod, test).
SPRING_PROFILES_ACTIVE=dev
# Logging level for the application (DEBUG, INFO, WARN, ERROR).
APP_LOG_LEVEL=INFO

