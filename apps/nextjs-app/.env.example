# ===================================================================
# NEXT.JS - SOURCE ENVIRONMENT VARIABLES
# ===================================================================
# This file contains environment variables for running Next.js locally
# Copy this to .env.local and update with your values

# Public API URL (Browser & default SSR fallback)
# This URL is exposed to the browser and used for all client-side API calls.
# Also used as fallback for server-side rendering when INTERNAL_API_URL is not set.
# Local: http://localhost:8080 | Prod: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# Internal API URL (SSR in Docker/VPC only)
# Used for server-side API calls within Docker containers or VPC networks.
# Enables direct container-to-container communication without going through public URLs.
# Uncomment and set when running in Docker Compose or cloud environments.
# INTERNAL_API_URL=http://backend:8080

# JWT Secret Key for token verification
# CRITICAL: Must exactly match the JWT_SECRET_KEY in the backend environment.
JWT_SECRET_KEY=
